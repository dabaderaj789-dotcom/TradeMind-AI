# Application
APP_NAME=TradeMind AI
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database — local Docker Compose defaults
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=trademind
POSTGRES_PASSWORD=trademind_secret
POSTGRES_DB=trademind_db
DATABASE_ECHO=false

# Neon (cloud): paste the connection string instead of POSTGRES_* above.
# Use the "direct" (non-pooler) URL for Alembic migrations.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# CORS (comma-separated origins). Include your LAN IP for iPhone / Wi-Fi access.
# After Vercel deploy, add: https://YOUR-TERMINAL.vercel.app,https://YOUR-STUDIO.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5175,http://192.168.0.133:5173,http://192.168.0.133:5175

# Optional: force the LAN IP printed for phones (auto-detected if unset)
# TRADEMIND_HOST=192.168.0.133

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
