# =============================================================================
# TradeMind AI — FastAPI + Neon + Vercel (production / free cloud)
# Paste into Neon / Render / Railway / Vercel dashboards. Do not commit secrets.
# =============================================================================

# ---- Neon PostgreSQL --------------------------------------------------------
# Use the direct (non-pooler) URI for Alembic migrations.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# ---- FastAPI (Render / Railway) ---------------------------------------------
APP_NAME=TradeMind AI
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_FORMAT=text
# Comma-separated exact Vercel origins (also allows *.vercel.app via regex)
CORS_ORIGINS=https://YOUR-TERMINAL.vercel.app,https://YOUR-STUDIO.vercel.app
# PORT is injected by the host

# ---- Vercel — Trading Terminal (Root Directory: terminal) -------------------
VITE_API_BASE=https://YOUR-API.onrender.com/api/v1

# ---- Vercel — Replay Studio (Root Directory: studio) ------------------------
VITE_API_BASE=https://YOUR-API.onrender.com/api/v1
VITE_BASE=/

# ---- One-time bootstrap from your PC ----------------------------------------
# TRADEMIND_API_BASE=https://YOUR-API.onrender.com/api/v1
# python scripts/bootstrap_market.py
